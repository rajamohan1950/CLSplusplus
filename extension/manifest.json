{
  "manifest_version": 3,
  "name": "CLS++ Memory",
  "version": "6.0.0",
  "description": "Every AI remembers you. Cross-model memory for ChatGPT, Claude, Gemini.",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://www.clsplusplus.com/*",
    "https://us.i.posthog.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "http://localhost/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://claude.ai/*", "https://gemini.google.com/*"],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*", "https://claude.ai/*", "https://gemini.google.com/*"],
      "js": ["capture.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": { "default_popup": "popup.html", "default_icon": { "48": "icons/icon48.png" } },
  "side_panel": { "default_path": "sidepanel.html" }
}
