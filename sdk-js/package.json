{
  "name": "clsplusplus",
  "version": "4.0.2",
  "description": "Brain-inspired, model-agnostic persistent memory for LLMs. Learn, recall, forget — like a brain. Works with OpenAI, Claude, Gemini, Llama.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "llm",
    "memory",
    "ai",
    "brain",
    "persistent-memory",
    "model-agnostic",
    "openai",
    "anthropic",
    "claude",
    "gemini",
    "langchain",
    "rag",
    "semantic-search",
    "vector-database",
    "conversational-ai",
    "context-window"
  ],
  "author": "AlphaForge AI Labs <contact@alphaforge.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajamohan1950/CLSplusplus.git",
    "directory": "sdk-js"
  },
  "homepage": "https://github.com/rajamohan1950/CLSplusplus#readme",
  "bugs": {
    "url": "https://github.com/rajamohan1950/CLSplusplus/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/rajamohan1950/CLSplusplus"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
